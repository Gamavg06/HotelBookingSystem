@page
@model HotelReservation.Pages.AccessModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Acceso - Hotel Reserva</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/site.css" />
</head>

<body class="bg-white">

    <!-- CONTENEDOR CENTRADO -->
    <div class="full-center">

        <!-- Banner pequeño independiente -->
        <div class="banner-box">
            <img src="/images/banner.png" class="banner-image" />
        </div>

        <!-- Cuadro de Bienvenido -->
        <div class="access-box text-center p-4">
            <h2 class="mb-4 text-white fw-bold">Bienvenido</h2>

            <a asp-page="/Login" class="btn btn-access mb-3 w-100">Iniciar sesión</a>
            <a asp-page="/Register" class="btn btn-access-outline w-100">Registrarse</a>
        </div>

    </div>

</body>
</html>
