@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model HotelReservation.Pages.RegisterModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Registro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body class="bg-light">

    <div class="container mt-5" style="max-width: 600px;">
        <h2 class="text-center mb-4">Registro</h2>

        <form method="post">

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Nombre</label>
                    <input asp-for="Input.Nombre" class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Apellido</label>
                    <input asp-for="Input.Apellido" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label>Edad</label>
                <input asp-for="Input.Edad" type="number" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Celular</label>
                <input asp-for="Input.Celular" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Nacionalidad</label>
                <input asp-for="Input.Nacionalidad" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Email</label>
                <input asp-for="Input.Email" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Contraseña</label>
                <input asp-for="Input.Password" type="password" class="form-control" />
            </div>

            <button class="btn btn-gold w-100">Crear cuenta</button>

        </form>
    </div>

</body>
</html>
