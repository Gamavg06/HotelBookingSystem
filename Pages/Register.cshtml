@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model HotelReservation.Pages.RegisterModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Registro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/site.css" />
</head>

<body class="bg-light">

    <div class="full-center access-bg">
        <!-- Banner -->
        <div class="banner-box">
            <img src="/images/logo.png" alt="Logo" class="banner-image" />
        </div>

        <!-- Recuadro de Registro -->
        <div class="access-box text-center">
            <h3 class="mb-3">Crear cuenta</h3>

            <form method="post">
                <div class="mb-2">
                    <input asp-for="Input.Nombre" class="form-control" placeholder="Nombre" />
                </div>
                <div class="mb-2">
                    <input asp-for="Input.Apellido" class="form-control" placeholder="Apellido" />
                </div>
                <div class="mb-2">
                    <input asp-for="Input.Edad" type="number" class="form-control" placeholder="Edad" />
                </div>
                <div class="mb-2">
                    <input asp-for="Input.Celular" class="form-control" placeholder="Celular" />
                </div>
                <div class="mb-2">
                    <input asp-for="Input.Nacionalidad" class="form-control" placeholder="Nacionalidad" />
                </div>
                <div class="mb-2">
                    <input asp-for="Input.Email" class="form-control" placeholder="Correo electrónico" />
                </div>
                <div class="mb-2">
                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Contraseña" />
                </div>
                <button type="submit" class="btn-access w-100">Registrarse</button>
            </form>

            <div class="mt-3">
                <a asp-page="/Login" class="btn-access-outline w-100">Ya tengo cuenta</a>
            </div>
        </div>
    </div>

</body>
</html>
