@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model HotelReservation.Pages.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Iniciar Sesión</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/site.css" />
</head>

<body class="bg-light">

    <div class="full-center access-bg">
        <!-- Banner -->
        <div class="banner-box">
            <img src="/images/logo.png" alt="Logo" class="banner-image" />
        </div>

        <!-- Recuadro de Bienvenido -->
        <div class="access-box text-center">
            <h3 class="mb-3">Bienvenido</h3>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form method="post">
                <div class="mb-3">
                    <input asp-for="Input.Email" class="form-control" placeholder="Correo electrónico" />
                </div>
                <div class="mb-3">
                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Contraseña" />
                </div>
                <button type="submit" class="btn-access w-100">Entrar</button>
            </form>

            <div class="mt-3">
                <a asp-page="/Register" class="btn-access-outline w-100">Registrarse</a>
            </div>
        </div>
    </div>

</body>
</html>
