@page
@model HotelReservation.Pages.AdminModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Panel de Administración";
}

<div class="container mt-5">
    <h2 class="text-center text-gold">Administration Panel</h2>
    <p class="text-center">Welcome, administrator. Here you can manage the reservation system.</p>

    <div class="row mt-4">
        <div class="col-md-4">
            <a asp-page="/Rooms" class="btn btn-gold w-100">Manage Rooms</a>
        </div>
        <div class="col-md-4">
            <a asp-page="/Reservation" class="btn btn-gold w-100">View Reservations</a>
        </div>
        <div class="col-md-4">
            <a asp-page="/Users" class="btn btn-gold w-100">Manage Users</a>
        </div>
    </div>
</div>
