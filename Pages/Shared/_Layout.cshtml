@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Hotel Reserva</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="site-header mb-4">
        <nav class="navbar navbar-expand-lg bg-white shadow-sm">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-page="/Index">
                    <img src="/images/logo.png" alt="Logo" class="logo me-2" />
                    <span class="brand-text">Hotel Reserva</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon">☰</span>
                </button>
                <div class="collapse navbar-collapse" id="navMenu">
                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (HttpContextAccessor.HttpContext.User.Identity?.IsAuthenticated ?? false)
                        {
                            var role = HttpContextAccessor.HttpContext.User.FindFirst("http://schemas.microsoft.com/ws/2008/06/identity/claims/role")?.Value;
                            var name = HttpContextAccessor.HttpContext.User.Identity?.Name;

                            if (role == "Admin")
                            {
                                <!-- Menú para Admin -->
                                <li class="nav-item"><a class="nav-link" asp-page="/Admin/Panel">Panel Admin</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Admin/Rooms/Index">Habitaciones</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Admin/Reservations/Index">Reservaciones</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Admin/Users/Index">Usuarios</a></li>
                            }
                            else
                            {
                                <!-- Menú para Usuario -->
                                <li class="nav-item"><a class="nav-link" asp-page="/Index">Inicio</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Rooms">Habitaciones</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Reservation">Reservar</a></li>
                            }

                            <!-- Mostrar nombre del usuario -->
                            <li class="nav-item">
                                <span class="nav-link text-muted">Hola, @name</span>
                            </li>

                            <!-- Botón dorado de Logout -->
                            <li class="nav-item">
                                <form asp-page="/Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-gold ms-2">Cerrar sesión</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <!-- Botones dorados de Login y Registro -->
                            <li class="nav-item">
                                <a asp-page="/Login" class="btn btn-gold ms-2">Login</a>
                            </li>
                            <li class="nav-item">
                                <a asp-page="/Register" class="btn btn-gold-outline ms-2">Registro</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <footer class="site-footer mt-5 py-4 bg-white border-top">
        <div class="container text-center">
            &copy; @DateTime.Now.Year Hotel Reserva.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
