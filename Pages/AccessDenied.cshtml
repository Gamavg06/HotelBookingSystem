@page
@{
    Layout = null;
}

<div class="full-center access-bg">
    <div class="banner-box">
        <img src="/images/logo.png" alt="Logo" class="banner-image" />
    </div>

    <div class="access-box text-center">
        <h2 class="mb-3 text-danger">Access Denied</h2>
        <p>You do not have permission to view this page.</p>

        <div class="mt-3">
            <a asp-page="/Login" class="btn-access w-100">Go to Login</a>
        </div>
        <div class="mt-2">
            <a asp-page="/Index" class="btn-access-outline w-100">Go to Home</a>
        </div>
    </div>
</div>
