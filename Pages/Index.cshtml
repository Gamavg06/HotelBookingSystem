@page
@model HotelReservation.Pages.IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<div class="hero container py-5 mb-5 d-flex align-items-center">

    <div class="hero-banner-left me-5">
        <div class="banner-box">
            <img src="/images/banner.png" class="banner-image" alt="Banner Hotel" />
        </div>
    </div>

    <div class="hero-right text-end flex-grow-1">
        <h1 class="display-6 fw-bold text-dark">Bienvenido a Hotel Reserva</h1>
        <p class="lead text-muted">Reserva tu estancia con facilidad y comodidad.</p>
        <a asp-page="/Rooms" class="btn btn-gold btn-lg px-4 mt-2">Ver habitaciones</a>
    </div>

</div>

<div class="row">
    @foreach (var r in Model.Rooms)
    {
        <div class="col-md-4">
            <div class="card mb-4 shadow-sm room-card">
                <img src="@r.Image" class="card-img-top" alt="@r.Name" />
                <div class="card-body">
                    <h5 class="card-title">@r.Name</h5>
                    <p class="card-text">@r.Description</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-page="/Reservation" asp-route-roomId="@r.Id" class="btn btn-sm btn-gold-outline">
                            Reservar
                        </a>
                        <small class="text-muted">$@r.PricePerNight.ToString("0.00") / noche</small>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
