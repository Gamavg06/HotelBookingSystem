@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model HotelReservation.Pages.RegisterModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Registro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/site.css" />
</head>

<body class="bg-light">

    <div class="full-center access-bg">
        <!-- Banner -->
        <div class="banner-box">
            <img src="/images/logo.png" alt="Logo" class="banner-image" />
        </div>

        <!-- Recuadro de Registro -->
        <div class="access-box text-center">
            <h3 class="mb-3">Create Account</h3>

            <form method="post">
                <div class="mb-2">
                    <input asp-for="Input.Name" class="form-control" placeholder="First Name" />
                </div>
                <div class="mb-2">
                    <input asp-for="Input.LastName" class="form-control" placeholder="Last Name" />
                </div>
                <div class="mb-2">
                    <input asp-for="Input.Age" type="number" class="form-control" placeholder="Age" />
                </div>
                <div class="mb-2">
                    <input asp-for="Input.Telephone" class="form-control" placeholder="Cell Phone" />
                </div>
                <div class="mb-2">
                    <input asp-for="Input.Nationality" class="form-control" placeholder="Nationality" />
                </div>
                <div class="mb-2">
                    <input asp-for="Input.Email" class="form-control" placeholder="Email" />
                </div>
                <div class="mb-2">
                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Password" />
                </div>
                <button type="submit" class="btn-access w-100">Register</button>
            </form>

            <div class="mt-3">
                <a asp-page="/Login" class="btn-access-outline w-100">I already have an account</a>
            </div>
        </div>
    </div>

</body>
</html>
