@page
@model HotelReservation.Pages.PaymentModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<div class="container mt-5" style="max-width:900px;">
    <h2 class="mb-4 text-center">Método de pago</h2>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (TempData["EmailPreview"] != null)
    {
        <div class="alert alert-info">
            <b>Email preview (Not sent, configuration missing):</b>
            <div style="white-space:pre-wrap;">@TempData["EmailPreview"]</div>
        </div>
    }

    <form method="post" novalidate>
        <div class="mb-3">
            <label class="form-label fw-bold">Payment Method</label>
            <select class="form-select" asp-for="Input.PaymentMethod" id="paymentSelect">
                <option value="">-- Select --</option>
                <option value="tarjeta">Credit / Debit Card</option>
                <option value="transferencia">Bank Transfer</option>
                <option value="paypal">PayPal</option>
            </select>
        </div>

        <div id="cardSection" class="p-3 border rounded mb-3 bg-light" style="display:none;">
            <label>Cardholder Name</label>
            <input asp-for="Input.CardName" class="form-control" />
            <label class="mt-2">Card Number</label>
            <input asp-for="Input.CardNumber" class="form-control" />
            <div class="row">
                <div class="col">
                    <label>Expiration</label>
                    <input asp-for="Input.ExpirationDate" class="form-control" />
                </div>
                <div class="col">
                    <label>CVV</label>
                    <input asp-for="Input.CVV" class="form-control" />
                </div>
            </div>
        </div>

        <div id="transferSection" class="p-3 border rounded mb-3 bg-light" style="display:none;">
            <label>Bank</label>
            <input asp-for="Input.BankName" class="form-control" />
            <label class="mt-2">Account Number</label>
            <input asp-for="Input.AccountNumber" class="form-control" />
        </div>

        <div id="paypalSection" class="p-3 border rounded mb-3 bg-light" style="display:none;">
            <label>PayPal Email</label>
            <input asp-for="Input.PayPalEmail" class="form-control" />
        </div>

        <div class="text-center mt-3">
            <button class="btn btn-gold btn-lg" type="submit">Confirm Payment</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        (function(){
            const select = document.getElementById('paymentSelect');
            const card = document.getElementById('cardSection');
            const transfer = document.getElementById('transferSection');
            const paypal = document.getElementById('paypalSection');
            function update(){
                const v = select.value;
                card.style.display = v === 'card' ? 'block' : 'none';
                transfer.style.display = v === 'transference' ? 'block' : 'none';
                paypal.style.display = v === 'paypal' ? 'block' : 'none';
            }
            select.addEventListener('change', update);
            update();
        })();
    </script>
}
